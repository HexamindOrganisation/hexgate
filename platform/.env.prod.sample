# Production environment for docker-compose.prod.yml. Copy to .env.prod and
# fill in. This file feeds BOTH:
#   • ${...} interpolation in the compose file (via `--env-file .env.prod`)
#   • the api container's environment (via the api service's `env_file:`)
#
# Generate secrets with:  openssl rand -base64 32 | tr -d '/+='
# (the `tr` strips URL-reserved chars — plain base64 emits / + = which corrupt
#  HEXGATE_POSTGRES_PASSWORD once it's embedded in DATABASE_URL; see below).
#
# NOT included here (the compose pins them, and `environment:` beats `env_file:`,
# so setting them here would have no effect): HEXGATE_CLICKHOUSE_HOST,
# HEXGATE_CLICKHOUSE_PORT, HEXGATE_KEYSTORE_PATH.

# ── Image source (optional) ──────────────────────────────────────────────
# The default deploy builds images on the machine (`make platform-prod-up`),
# so these are NOT needed — leave them unset and the local image tag defaults
# to hexgate/...:latest. Only set them if you instead pull prebuilt images
# from a registry.
# REGISTRY=rg.fr-par.scw.cloud/<your-namespace>
# TAG=latest

# ── Public domain ────────────────────────────────────────────────────────
# Caddy's site address + the host it requests a Let's Encrypt cert for. A DNS
# A-record for this name MUST point at the instance BEFORE first boot, or the
# ACME challenge fails. (For a local HTTP smoke test only, use ":80".)
HEXGATE_DOMAIN=app.example.com

# ── Postgres ─────────────────────────────────────────────────────────────
# Single source of truth for the DB password: it initialises the postgres
# container AND the compose file derives the API's DATABASE_URL from it
# (postgresql+asyncpg://hexgate:${HEXGATE_POSTGRES_PASSWORD}@postgres:5432/hexgate),
# so there is no second copy to keep in sync.
# Because it's embedded in that URL, the password MUST be URL-safe: no @ : / # ?
# (SQLAlchemy would mis-split the URL on them). Use the URL-safe generator above,
# or percent-encode any reserved chars if you choose the password by hand.
HEXGATE_POSTGRES_PASSWORD=<strong-password>

# ── ClickHouse ───────────────────────────────────────────────────────────
# Used by both the clickhouse container and the API. MANDATORY: settings.py
# refuses to start if the API points at a non-local ClickHouse host (it does:
# `clickhouse`) while this is still the committed dev default.
HEXGATE_CLICKHOUSE_PASSWORD=<strong-password>

# ── Web security ─────────────────────────────────────────────────────────
# HTTPS at the edge → secure cookies. =1 sets Secure on session + OAuth CSRF
# cookies; leaving it off would make them unusable over HTTPS.
HEXGATE_COOKIE_SECURE=1
# Same-origin deploy: the SPA and API share https://<domain>, so links in
# verify/reset/invite emails resolve correctly here.
HEXGATE_DASHBOARD_URL=https://app.example.com
# Same-origin means CORS is never actually exercised, but set it explicitly to
# the real origin so the dev localhost:5173 default never leaks into prod.
HEXGATE_CORS_ORIGINS=https://app.example.com

# ── Bootstrap ────────────────────────────────────────────────────────────
# `skip` opts out of the passwordless seeded admin/org/project. The first admin
# self-registers via POST /v1/auth/register (or Google sign-in) on first boot.
HEXGATE_SEED=skip
#
# DO NOT set these in production:
#   HEXGATE_DEMO                 — enables a PASSWORDLESS /v1/demo-login session
#   HEXGATE_ALLOW_DEV_USER_HEADER — trusts a client-supplied user header

# ── Google OAuth (optional) ──────────────────────────────────────────────
# Set both to enable "Sign in with Google". The redirect URI is derived from
# the request host, so register this callback in the Google console:
#   https://app.example.com/v1/auth/google/callback
# HEXGATE_GOOGLE_CLIENT_ID=<client-id>
# HEXGATE_GOOGLE_CLIENT_SECRET=<client-secret>
