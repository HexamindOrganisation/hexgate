# Production env for docker-compose.prod.yml. Copy to .env.prod and fill in.
# Generate secrets: openssl rand -base64 32 | tr -d '/+='   (URL-safe; see Postgres)
# Pinned by the compose, not here: HEXGATE_CLICKHOUSE_HOST/PORT, HEXGATE_KEYSTORE_PATH.

# ── Image source (optional) ──────────────────────────────────────────────
# Build-on-target needs neither; set only to pull prebuilt images from a registry.
# REGISTRY=rg.fr-par.scw.cloud/<your-namespace>
# TAG=latest

# ── Public domain ────────────────────────────────────────────────────────
# Caddy site address + Let's Encrypt host. The DNS A-record must point here
# before first boot (ACME). Use ":80" for a local HTTP smoke test.
HEXGATE_DOMAIN=app.example.com

# ── Postgres ─────────────────────────────────────────────────────────────
# The API's DATABASE_URL is derived from this in the compose, so it's the only
# copy. Must be URL-safe (no @ : / # ?) — it's embedded in that URL.
HEXGATE_POSTGRES_PASSWORD=<strong-password>

# ── ClickHouse ───────────────────────────────────────────────────────────
# Mandatory: the API refuses to start against the non-local `clickhouse` host
# with the committed dev default.
HEXGATE_CLICKHOUSE_PASSWORD=<strong-password>

# ── Web security ─────────────────────────────────────────────────────────
HEXGATE_COOKIE_SECURE=1                         # Secure cookies (required over HTTPS)
HEXGATE_DASHBOARD_URL=https://app.example.com   # used in verify/reset/invite email links
HEXGATE_CORS_ORIGINS=https://app.example.com    # explicit so the dev default never leaks

# ── Bootstrap ────────────────────────────────────────────────────────────
# skip = no seeded passwordless admin; first admin self-registers via
# POST /v1/auth/register (or Google). Never set HEXGATE_DEMO or
# HEXGATE_ALLOW_DEV_USER_HEADER in prod.
HEXGATE_SEED=skip

# ── Google OAuth (optional) ──────────────────────────────────────────────
# Register the callback https://app.example.com/v1/auth/google/callback in the console.
# HEXGATE_GOOGLE_CLIENT_ID=<client-id>
# HEXGATE_GOOGLE_CLIENT_SECRET=<client-secret>
