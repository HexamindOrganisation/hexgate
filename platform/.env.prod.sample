# PROD env for docker-compose.deploy.yml. Copy to .env.prod and fill in.
# Generate secrets: openssl rand -base64 32
# Pinned by the compose, not here: HEXGATE_CLICKHOUSE_HOST/PORT, HEXGATE_KEYSTORE_PATH.
# TLS is terminated by the box's reverse proxy upstream; the api speaks plain HTTP.

# ── Environment identity ─────────────────────────────────────────────────
# HEXGATE_ENV selects which .env the api container loads (must match this
# file's suffix). TAG keeps this env's locally-built images distinct from other
# envs on the box. HEXGATE_HTTP_PORT is the loopback port the box's reverse proxy hits.
HEXGATE_ENV=prod
TAG=prod
HEXGATE_HTTP_PORT=7000

# Optional: set only to pull prebuilt images from a registry instead of building.
# REGISTRY=rg.fr-par.scw.cloud/<your-namespace>

# ── Postgres ─────────────────────────────────────────────────────────────
# The API assembles its DATABASE_URL from this (percent-encoding it), so this is
# the only copy and the password may contain ANY characters — no URL-safe limit.
HEXGATE_POSTGRES_PASSWORD=<strong-password>

# ── ClickHouse ───────────────────────────────────────────────────────────
# Mandatory: the API refuses to start against the non-local `clickhouse` host
# with the committed dev default.
HEXGATE_CLICKHOUSE_PASSWORD=<strong-password>

# ── Web security ─────────────────────────────────────────────────────────
# Public URL is https via the box's reverse proxy, so cookies must be Secure.
HEXGATE_COOKIE_SECURE=1
HEXGATE_DASHBOARD_URL=https://app.hexgate.ai    # verify/reset/invite email links
HEXGATE_CORS_ORIGINS=https://app.hexgate.ai     # explicit so the dev default never leaks

# ── Bootstrap ────────────────────────────────────────────────────────────
# skip = no seeded passwordless admin; first admin self-registers via
# POST /v1/auth/register (or Google). Never set HEXGATE_DEMO or
# HEXGATE_ALLOW_DEV_USER_HEADER in prod.
HEXGATE_SEED=skip

# ── Google OAuth (optional) ──────────────────────────────────────────────
# Register the callback https://app.hexgate.ai/v1/auth/google/callback in the console.
# HEXGATE_GOOGLE_CLIENT_ID=<client-id>
# HEXGATE_GOOGLE_CLIENT_SECRET=<client-secret>
