# Edge: TLS-terminating reverse proxy + SPA host. {$HEXGATE_DOMAIN} from env:
# a real host → Let's Encrypt; ":80" → plain HTTP (local smoke test).
{$HEXGATE_DOMAIN} {
	encode gzip zstd

	# API + WebSocket (Caddy upgrades WS transparently). `api` = compose service.
	handle /v1/* {
		reverse_proxy api:8000
	}

	# SPA: fall back to index.html so client-side routes survive a hard refresh.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
