# Context is the repo ROOT. BuildKit uses this file INSTEAD of the repo-root
# .dockerignore (which excludes platform/dashboard/ — the source the edge needs).
# Allowlist: drop everything, re-include only what the build COPYs.
*
!platform
platform/*
!platform/dashboard
!platform/edge

# Deps/artifacts are rebuilt in the image.
platform/dashboard/node_modules
platform/dashboard/dist
platform/dashboard/.vite
**/.DS_Store
**/*.log
