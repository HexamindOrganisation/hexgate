# STAGING env for docker-compose.deploy.yml. Copy to .env.staging and fill in.
# Identical to .env.prod.sample except TAG, HEXGATE_HTTP_PORT, and the hostname.
# Generate secrets: openssl rand -base64 32

# ── Environment identity ─────────────────────────────────────────────────
# HEXGATE_ENV must match this file's suffix — it's what makes the api container
# load .env.staging (not .env.prod).
HEXGATE_ENV=staging
TAG=staging
HEXGATE_HTTP_PORT=7200

# Optional: pull prebuilt images instead of building.
# REGISTRY=rg.fr-par.scw.cloud/<your-namespace>

# ── Postgres ─────────────────────────────────────────────────────────────
# Percent-encoded by the API into its DATABASE_URL — may contain ANY characters.
HEXGATE_POSTGRES_PASSWORD=<strong-password>

# ── ClickHouse ───────────────────────────────────────────────────────────
HEXGATE_CLICKHOUSE_PASSWORD=<strong-password>

# ── Web security ─────────────────────────────────────────────────────────
HEXGATE_COOKIE_SECURE=1
HEXGATE_DASHBOARD_URL=https://app.staging.hexgate.ai
HEXGATE_CORS_ORIGINS=https://app.staging.hexgate.ai

# ── Email (Resend) ───────────────────────────────────────────────────────
# Empty RESEND_API_KEY keeps the dev stderr sender (links logged, nothing
# delivered); set it to enable real Resend delivery. HEXGATE_EMAIL_FROM is the
# From header — its domain must be verified in Resend.
RESEND_API_KEY=
HEXGATE_EMAIL_FROM="Hexgate <noreply@mail.hexgate.ai>"

# ── Dashboard build (build-time) ─────────────────────────────────────────
# Shows the "Preview — beta, data may be reset" strip. BUILD-TIME: Vite bakes
# this into the SPA bundle, so it only takes effect on `make platform-staging-up`
# (which rebuilds). Set to empty/remove to hide the banner.
VITE_PREVIEW_BANNER=1

# ── Bootstrap ────────────────────────────────────────────────────────────
HEXGATE_SEED=skip

# ── Google OAuth (optional) ──────────────────────────────────────────────
# Register the callback https://app.staging.hexgate.ai/v1/auth/google/callback.
# HEXGATE_GOOGLE_CLIENT_ID=<client-id>
# HEXGATE_GOOGLE_CLIENT_SECRET=<client-secret>
