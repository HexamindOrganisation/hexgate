.env
# Real env files carry secrets; keep the *.sample templates tracked.
.env.*
!.env.sample
!.env.*.sample
.ruff_cache/
__pycache__/
*.db
*.pyc
*.pyo
*.pyd
*.egg-info/
build/
.DS_Store
.venv/

# Vendored numpy etc. show up here when shell PYTHONPATH points at ~/Library
Library/

# Ed25519 signing keys from `hexgate policy keygen` — never commit the private key.
*.private
*.pem

# hexgate live-demo scratch
platform/api/hexgate.db
__marimo__/

# Coverage artifacts — pytest-cov + vitest @vitest/coverage-v8 emit these,
# uploaded to Codecov from CI, never committed.
.coverage
.coverage.*
coverage.xml
htmlcov/
platform/dashboard/coverage/
