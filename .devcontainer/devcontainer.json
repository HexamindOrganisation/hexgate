{
  "name": "Hexgate live demo",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },

  // marimo notebook + the dashboard/API. Forwarded directly (no reverse proxy),
  // so marimo's WebSocket works — which is what broke under Modal's web_server.
  "forwardPorts": [2718, 8000],
  "portsAttributes": {
    "2718": { "label": "Notebook (marimo)", "onAutoForward": "openBrowser" },
    "8000": { "label": "Dashboard + API", "onAutoForward": "silent" }
  },

  // One-time build after the container is created (cached for the codespace's
  // life; use GitHub Prebuilds to make this instant for visitors).
  "postCreateCommand": "bash .devcontainer/setup.sh",
  // Launch the demo on attach (guarded against double-start on reconnect).
  "postAttachCommand": "bash .devcontainer/start.sh",

  "hostRequirements": { "cpus": 2, "memory": "8gb" }
}
